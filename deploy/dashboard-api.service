[Unit]
Description=Personal Dashboard API
After=network.target postgresql.service

[Service]
User=dthewind
WorkingDirectory=/home/dthewind/personal-dashboard/backend
EnvironmentFile=/home/dthewind/personal-dashboard/backend/.env
ExecStart=/home/dthewind/personal-dashboard/backend/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8001
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
